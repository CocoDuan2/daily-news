<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ day }} AI 资讯</title>
    <style>
      body { margin: 0; font-family: Inter, ui-sans-serif, system-ui, -apple-system, sans-serif; background: #0b1020; color: #e9eefc; }
      .container { max-width: 980px; margin: 0 auto; padding: 32px 20px 60px; }
      a { color: #74c0fc; text-decoration: none; }
      .nav { margin-bottom: 24px; color: #a8b3cf; }
      .card { background: #121933; border: 1px solid #253056; border-radius: 16px; padding: 18px; margin-bottom: 14px; }
      .source { color: #74c0fc; font-weight: 700; font-size: 14px; }
      .summary, .meta { color: #a8b3cf; }
    </style>
  </head>
  <body>
    <main class="container">
      <div class="nav"><a href="{{ home_url }}">返回首页</a> · <a href="{{ archive_index_url }}">历史归档</a></div>
      <h1>{{ day }} AI 资讯</h1>
      {% for entry in entries %}
        <article class="card">
          <div class="source">{{ entry.source }}</div>
          <h2><a href="{{ entry.link }}" target="_blank" rel="noreferrer">{{ entry.title }}</a></h2>
          <div class="meta">{{ entry.published.strftime('%Y-%m-%d %H:%M UTC') }}</div>
          <p class="summary">{{ entry.summary }}</p>
        </article>
      {% endfor %}
    </main>
  </body>
</html>
